[Unit]
Description=FalconEye NVD CVE ingest worker
After=network-online.target
Wants=network-online.target
OnSuccess=falconeye-ssg.service

[Service]
Type=oneshot
User=falconeye
Group=falconeye
WorkingDirectory=/opt/falconeye/src
EnvironmentFile=/opt/falconeye/config/secrets.env
ExecStart=/opt/falconeye/venv/bin/python -m falconeye.ingest.nvd
StandardOutput=journal
StandardError=journal
SyslogIdentifier=falconeye-nvd

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/falconeye/db /opt/falconeye/logs
