# FalconEye environment configuration
# Copy this file to /opt/falconeye/.env on your VPS and fill in the values you have.
# All keys are optional - the relevant tab degrades gracefully if a key is missing.

# ----- LLM features -----
# Anthropic API key for the Email Header LLM analysis, Dork Generator, and Script Decoder.
# Get one at https://console.anthropic.com (free $5 credit on signup at time of writing).
# Strongly recommended: set a monthly spend limit in the Anthropic Console before deploying.
ANTHROPIC_API_KEY=

# Kill switches for individual LLM-powered tabs. Set to "false" to disable.
LLM_ANALYSIS_ENABLED=true
LLM_DORKGEN_ENABLED=true
LLM_DECODER_ENABLED=true

# ----- IP Reputation tab -----
# Shodan free account: https://account.shodan.io (used by IP Reputation tab AND Phishing Scanner)
SHODAN_API_KEY=

# GreyNoise Community: https://viz.greynoise.io/account
GREYNOISE_API_KEY=

# ----- Sandbox History tab -----
# abuse.ch auth key (free): https://auth.abuse.ch
ABUSECH_AUTH_KEY=

# ----- Internal -----
# Path to the SQLite database. Default works on most installs.
DB_PATH=/opt/falconeye/data/falconeye.db
