# FalconEye environment configuration
# Copy this file to /opt/falconeye/.env on your VPS and fill in the values you have.
# All keys are optional - the relevant tab degrades gracefully if a key is missing.

# ----- LLM features -----
# Anthropic API key for the Email Header LLM analysis, Dork Generator, and Script Decoder.
# Get one at https://console.anthropic.com (free $5 credit on signup at time of writing).
# Strongly recommended: set a monthly spend limit in the Anthropic Console before deploying.
ANTHROPIC_API_KEY=

# Kill switches for individual LLM-powered tabs. Set to "false" to disable.
LLM_ANALYSIS_ENABLED=true
LLM_DORKGEN_ENABLED=true
LLM_DECODER_ENABLED=true

# ----- IP Reputation tab -----
# Shodan free account: https://account.shodan.io (used by IP Reputation tab AND Phishing Scanner)
SHODAN_API_KEY=

# GreyNoise Community: https://viz.greynoise.io/account
GREYNOISE_API_KEY=

# ----- Sandbox History tab -----
# abuse.ch auth key (free): https://auth.abuse.ch
ABUSECH_AUTH_KEY=

# ----- Prospect tab -----
# SearchAPI.io key for the Prospect commercial intelligence tab.
# Get one at https://www.searchapi.io (free trial available).
# NEVER log, echo, or expose this value.
SEARCHAPI_KEY=

# Kill switch for the Prospect tab. Set to "false" to disable without redeploying.
PROSPECT_ENABLED=true

# Redis connection URL for Prospect response cache (6-hour TTL).
# Defaults to local Redis on standard port. Set if Redis runs elsewhere.
# REDIS_URL=redis://localhost:6379

# ----- Image Search tab -----
# Same SearchAPI.io key used by the Prospect tab (see above).
# Kill switch: set to "false" to disable without redeploying.
IMAGE_SEARCH_ENABLED=true
IMAGE_SEARCH_YANDEX_ENABLED=true

# HMAC secret for signed upload URLs. Generate with: openssl rand -hex 32
# NEVER log, echo, or expose this value. Required if IMAGE_SEARCH_ENABLED=true.
IMAGE_UPLOAD_SECRET=

# Public origin used in signed URL construction. Must match your domain.
SITE_ORIGIN=https://falconeye.osintph.info

# ----- Security -----
# Set to "true" ONLY in local development to enable /openapi.json, /api/docs, and /redoc.
# Must be unset or "false" in production — these endpoints expose the full API surface.
# FALCONEYE_PUBLIC_DOCS=true

# ----- Internal -----
# Path to the SQLite database. Default works on most installs.
DB_PATH=/opt/falconeye/data/falconeye.db
