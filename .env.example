# FalconEye environment configuration
# Copy this file to /opt/falconeye/.env on your VPS and fill in the values.
# All keys are optional unless marked REQUIRED — the relevant feature degrades
# gracefully if a key is absent, except where REQUIRED means the app will fail
# to start or that feature will crash on use.
#
# After editing: chmod 600 /opt/falconeye/.env

# ----- Database -----
# Path to the SQLite database file. The default works for standard installs.
# The code reads FALCONEYE_DB (not DB_PATH — an older alias that was retired).
# Upgrading from v3.4.0 or earlier: rename DB_PATH= to FALCONEYE_DB= in this file.
FALCONEYE_DB=/opt/falconeye/data/falconeye.db

# Directory for transient data (image upload temp files, etc.).
# Defaults to /opt/falconeye/data. Rarely needs changing.
# FALCONEYE_DATA_DIR=/opt/falconeye/data

# ----- LLM features -----
# Anthropic API key for Email Header LLM analysis, Dork Generator, and Script Decoder.
# Get one at https://console.anthropic.com. Set a monthly spend limit before deploying.
# Also install the SDK: pip install "anthropic>=0.25"
ANTHROPIC_API_KEY=

# Kill switches for individual LLM-powered tabs. Set to "false" to disable.
LLM_ANALYSIS_ENABLED=true
LLM_DORKGEN_ENABLED=true
LLM_DECODER_ENABLED=true

# ----- IP Reputation tab -----
# GreyNoise Community API: https://viz.greynoise.io/account
GREYNOISE_API_KEY=

# ----- Sandbox History tab -----
# abuse.ch auth key (free): https://auth.abuse.ch
# Used by Sandbox History and IP Reputation tabs.
ABUSECH_AUTH_KEY=

# ----- Prospect tab -----
# SearchAPI.io key. REQUIRED if PROSPECT_ENABLED=true.
# Also used by the Image Search tab (same key, two features).
# Get one at https://www.searchapi.io (free trial available).
# NEVER log, echo, or commit this value.
SEARCHAPI_KEY=

# Kill switch for the Prospect tab. Set to "false" to disable without redeploying.
PROSPECT_ENABLED=true

# Redis connection URL for Prospect response cache (6-hour TTL).
# Defaults to local Redis on the standard port.
# REDIS_URL=redis://localhost:6379

# ----- Image Search tab -----
# Kill switches for the Image Search tab and Yandex sub-engine.
IMAGE_SEARCH_ENABLED=true
IMAGE_SEARCH_YANDEX_ENABLED=true

# HMAC secret for signed temporary upload URLs. REQUIRED if IMAGE_SEARCH_ENABLED=true.
# Generate a fresh value: openssl rand -hex 32
# NEVER log, echo, or commit this value.
IMAGE_UPLOAD_SECRET=

# Public origin used in signed URL construction. Must match your deployed domain.
SITE_ORIGIN=https://falconeye.osintph.info

# ----- Phishing Scanner enrichment -----
# urlscan.io API key (optional). Without a key, the free tier works at a lower
# rate limit. Get one at https://urlscan.io/user/profile/ (free account).
# URLSCAN_API_KEY=

# ----- Abuse Reporting (IP Reputation + Email Header tabs) -----
# Reporter identity. REQUIRED for the /api/abuse/compose endpoint (the Preview
# button). Abuse desks ignore anonymous reports, so both must be set. The
# reply-to address must be a real inbox you check — replies land there.
FALCONEYE_REPORTER_NAME="Your Name, Your Org"
FALCONEYE_REPORTER_EMAIL="abuse-reports@example.com"

# Mailgun send (OPTIONAL — only needed for the "Send via Mailgun" button).
# Leave MAILGUN_API_KEY blank to run in compose-and-copy-only mode.
# NEVER log, echo, or commit MAILGUN_API_KEY.
MAILGUN_API_KEY=
# Your Mailgun-verified sending domain. The domain part of MAILGUN_FROM below
# MUST match this exactly or Mailgun silently rejects the send.
MAILGUN_DOMAIN=email.example.com
# Mailgun account region: "us" (api.mailgun.net) or "eu" (api.eu.mailgun.net).
# No inline comments on this line — set the bare value only.
MAILGUN_REGION=us
# From address. Must be at MAILGUN_DOMAIN.
MAILGUN_FROM=reports@email.example.com

# Admin HTTP Basic Auth for the send endpoint. FALCONEYE_ABUSE_ADMIN_PASS_HASH
# is a bcrypt hash (starts with $2b$), NOT a plaintext password. Generate with:
#   python3 -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"
FALCONEYE_ABUSE_ADMIN_USER=admin
FALCONEYE_ABUSE_ADMIN_PASS_HASH=

# ----- Security / Developer -----
# Set to "true" ONLY in local development to enable /openapi.json, /api/docs, /redoc.
# Must be unset or "false" in production — these endpoints expose the full API surface.
# FALCONEYE_PUBLIC_DOCS=true
