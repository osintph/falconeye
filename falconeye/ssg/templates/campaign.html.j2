<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{{ campaign.name }} — FalconEye</title>
<link rel="stylesheet" href="/falconeye.css?v={{ manifest_version }}">
</head>
<body>
<div class="nav">
  <a href="/">← Dashboard</a> ·
  <a href="/campaign/">All campaigns</a>
</div>

<h1>
  {{ campaign.name }}
  <span class="badge {{ campaign.status }}">{{ campaign.status }}</span>
</h1>
<p class="meta">
  {{ campaign.ioc_count }} IOCs ·
  first seen {{ (campaign.first_seen or '')[:10] or '—' }} ·
  last seen {{ (campaign.last_seen or '')[:10] or '—' }} ·
  type: {{ campaign.campaign_type }} ·
  generated {{ generated_at }} UTC
</p>

{% if campaign.summary %}
<p>{{ campaign.summary }}</p>
{% endif %}

<div class="cluster-key">Cluster key: <code>{{ campaign.cluster_key }}</code></div>

{% if guidance %}
<h2>Recommended defensive actions</h2>
{% for g in guidance %}
<div class="guidance-block">
  <div class="guidance-title">{{ g.title }}</div>
  {% if g.ports %}
  <p class="guidance-ports"><strong>Relevant ports:</strong>
    {% for p in g.ports %}<code>{{ p }}</code>{% if not loop.last %}, {% endif %}{% endfor %}
  </p>
  {% endif %}
  <p>{{ g.guidance }}</p>
  {% if g.rule_ref %}
  <p class="guidance-ref"><a href="{{ g.rule_ref }}" rel="noopener">Reference / detection rules ↗</a></p>
  {% endif %}
</div>
{% endfor %}
{% endif %}

{% if abuse_contact %}
<div class="guidance-block">
  <div class="guidance-title">Report to ISP abuse team</div>
  <p>
    <strong>{{ abuse_contact.name }}</strong>
    {% if abuse_contact.abuse_email %}
    — abuse: <a href="mailto:{{ abuse_contact.abuse_email }}">{{ abuse_contact.abuse_email }}</a>
    {% endif %}
    {% if abuse_contact.noc_email %}
    · NOC: <a href="mailto:{{ abuse_contact.noc_email }}">{{ abuse_contact.noc_email }}</a>
    {% endif %}
  </p>
</div>
{% endif %}

<h2>IOCs in this campaign ({{ iocs | length }})</h2>
{% if iocs %}
<table>
  <thead>
    <tr>
      <th>Type</th>
      <th>Value</th>
      <th>Threat type</th>
      <th>Tags</th>
      <th>Seen</th>
      <th>Pivot</th>
    </tr>
  </thead>
  <tbody>
    {% for ioc in iocs %}
    <tr>
      <td>{{ ioc.ioc_type }}</td>
      <td><code>{{ ioc.ioc_value }}</code></td>
      <td>{{ ioc.threat_type or '—' }}</td>
      <td>
        {% for t in (ioc.tags | from_json) %}
        <span class="tag-pill">{{ t }}</span>
        {% endfor %}
      </td>
      <td>{{ (ioc.fetched_at or '')[:10] }}</td>
      <td class="pivot-links">
        {% if ioc.ioc_type == 'ip' %}
          <a href="https://www.abuseipdb.com/check/{{ ioc.ioc_value }}" rel="noopener">AbuseIPDB</a>
          <a href="https://www.shodan.io/host/{{ ioc.ioc_value }}" rel="noopener">Shodan</a>
          <a href="https://www.virustotal.com/gui/ip-address/{{ ioc.ioc_value }}" rel="noopener">VT</a>
          <a href="https://bgp.he.net/ip/{{ ioc.ioc_value }}" rel="noopener">HE.net</a>
        {% elif ioc.ioc_type == 'url' %}
          {% if ioc.source == 'urlhaus' and ioc.source_id %}
          <a href="https://urlhaus.abuse.ch/url/{{ ioc.source_id }}/" rel="noopener">URLhaus</a>
          {% endif %}
          {% if ioc.pivot_domain %}
          <a href="https://www.virustotal.com/gui/domain/{{ ioc.pivot_domain }}" rel="noopener">VT</a>
          {% endif %}
        {% elif ioc.ioc_type == 'domain' %}
          <a href="https://www.virustotal.com/gui/domain/{{ ioc.ioc_value }}" rel="noopener">VT</a>
          {% if ioc.source == 'urlhaus' and ioc.source_id %}
          <a href="https://urlhaus.abuse.ch/url/{{ ioc.source_id }}/" rel="noopener">URLhaus</a>
          {% endif %}
        {% endif %}
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
<p class="zero">No IOC detail available.</p>
{% endif %}

<p class="meta">
  <a href="/">Dashboard</a> ·
  <a href="/campaign/">All campaigns</a> ·
  <a href="/asn/">ASNs</a> ·
  <a href="https://github.com/osintph/falconeye">GitHub</a> · AGPL v3
</p>
</body>
</html>
