<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{{ campaign.name }} — FalconEye</title>
<link rel="stylesheet" href="/falconeye.css?v={{ manifest_version }}">
</head>
<body>
<div class="nav">
  <a href="/">← Dashboard</a> ·
  <a href="/campaign/">All campaigns</a>
</div>

<h1>
  {{ campaign.name }}
  <span class="badge {{ campaign.status }}">{{ campaign.status }}</span>
</h1>
<p class="meta">
  {{ campaign.ioc_count }} IOCs ·
  first seen {{ (campaign.first_seen or '')[:10] or '—' }} ·
  last seen {{ (campaign.last_seen or '')[:10] or '—' }} ·
  type: {{ campaign.campaign_type }} ·
  generated {{ generated_at }} UTC
</p>

{% if campaign.summary %}
<p>{{ campaign.summary }}</p>
{% endif %}

<div class="cluster-key">Cluster key: <code>{{ campaign.cluster_key }}</code></div>

{% if guidance %}
<h2>Recommended defensive actions</h2>
{% for g in guidance %}
<div class="guidance-block">
  <div class="guidance-title">{{ g.title }}</div>
  {{ g.guidance }}
</div>
{% endfor %}
{% endif %}

<h2>IOCs in this campaign ({{ iocs | length }})</h2>
{% if iocs %}
<table>
  <thead>
    <tr>
      <th>Type</th>
      <th>Value</th>
      <th>Threat type</th>
      <th>Tags</th>
      <th>Seen</th>
    </tr>
  </thead>
  <tbody>
    {% for ioc in iocs %}
    <tr>
      <td>{{ ioc.ioc_type }}</td>
      <td>{{ ioc.ioc_value }}</td>
      <td>{{ ioc.threat_type or '—' }}</td>
      <td>
        {% for t in (ioc.tags | from_json) %}
        <span class="tag-pill">{{ t }}</span>
        {% endfor %}
      </td>
      <td>{{ (ioc.fetched_at or '')[:10] }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
<p class="zero">No IOC detail available.</p>
{% endif %}

<p class="meta">
  <a href="/">Dashboard</a> ·
  <a href="/campaign/">All campaigns</a> ·
  <a href="/asn/">ASNs</a> ·
  <a href="https://github.com/osintph/falconeye">GitHub</a> · AGPL v3
</p>
</body>
</html>
