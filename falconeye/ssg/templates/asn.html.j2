<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>AS{{ asn }} {{ operator_short }} — FalconEye</title>
<link rel="stylesheet" href="/falconeye.css?v={{ manifest_version }}">
</head>
<body>
<div class="nav">
  <a href="/">← Dashboard</a> ·
  <a href="/asn/">All ASNs</a>
</div>

<h1>AS{{ asn }} — {{ operator_name }}</h1>
<p class="meta">generated {{ generated_at }} UTC</p>

{% if prefixes %}
<div class="prefix-list">
  {% for p in prefixes %}
  <span class="prefix-tag">{{ p.prefix }}</span>
  {% endfor %}
</div>
{% endif %}

<h2>Weekly IOC activity (last 12 weeks)</h2>
{% if sparkline_svg %}
<div class="sparkline-block">
  <span class="sr-only">Weekly IOC counts (oldest to newest): {{ weekly_counts | join(', ') }}</span>
  {{ sparkline_svg | safe }}
  <span class="meta">{{ weekly_counts | sum }} IOCs in window</span>
</div>
{% else %}
<p class="zero">No IOC activity in the last 12 weeks.</p>
{% endif %}

<h2>IOCs on AS{{ asn }} prefixes (last 30 days)</h2>
{% if iocs %}
<table>
  <thead>
    <tr>
      <th>Type</th>
      <th>Value</th>
      <th>Threat type</th>
      <th>Tags</th>
      <th>Seen</th>
    </tr>
  </thead>
  <tbody>
    {% for ioc in iocs %}
    <tr>
      <td>{{ ioc.ioc_type }}</td>
      <td>{{ ioc.ioc_value }}</td>
      <td>{{ ioc.threat_type or '—' }}</td>
      <td>
        {% set tags = ioc.tags | default('[]') %}
        {% for t in (tags | from_json) %}
        <span class="tag-pill">{{ t }}</span>
        {% endfor %}
      </td>
      <td>{{ (ioc.fetched_at or '')[:10] }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
<p class="zero">No PH-matched IOCs on AS{{ asn }} prefixes in the last 30 days.</p>
{% endif %}

{% if enrichments %}
<h2>Shodan enrichment</h2>
<table>
  <thead>
    <tr>
      <th>IP</th>
      <th>Open ports</th>
      <th>CPEs</th>
      <th>Tags</th>
      <th>Vulns</th>
      <th>Enriched</th>
    </tr>
  </thead>
  <tbody>
    {% for e in enrichments %}
    <tr>
      <td><a href="https://internetdb.shodan.io/{{ e.ip_address }}">{{ e.ip_address }}</a></td>
      <td>{{ (e.ports | from_json) | join(', ') }}</td>
      <td class="zero">{{ (e.cpes | from_json) | length }} CPEs</td>
      <td>
        {% for t in (e.tags | from_json) %}
        <span class="tag-pill">{{ t }}</span>
        {% endfor %}
      </td>
      <td>{{ (e.vulns | from_json) | join(', ') or '—' }}</td>
      <td>{{ (e.fetched_at or '')[:10] }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}

<p class="meta">
  <a href="/">Dashboard</a> ·
  <a href="/asn/">All PH ASNs</a> ·
  <a href="https://github.com/osintph/falconeye">GitHub</a> · AGPL v3
</p>
</body>
</html>
