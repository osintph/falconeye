<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FalconEye — PH Threat Intelligence</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { font-family: system-ui, -apple-system, sans-serif; max-width: 1400px;
           margin: 0 auto; padding: 1rem 1.5rem; color: #1a1a1a; background: #fff; }
    a { color: #1a56a5; }
    h1 { margin: 0 0 0.25rem; font-size: 1.6rem; color: #b91c1c; }
    h2 { font-size: 1.1rem; margin: 1.5rem 0 0.5rem; border-bottom: 1px solid #e5e7eb; padding-bottom: 4px; }
    .meta { font-size: 0.8rem; color: #6b7280; margin-bottom: 1rem; }
    .stats { display: flex; gap: 1rem; flex-wrap: wrap; margin: 0.75rem 0 1.25rem; }
    .stat { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 6px;
            padding: 0.5rem 1rem; min-width: 110px; }
    .stat-n { font-size: 1.4rem; font-weight: 700; color: #111; }
    .stat-l { font-size: 0.72rem; color: #6b7280; }
    table { width: 100%; border-collapse: collapse; font-size: 0.8rem; }
    th, td { text-align: left; padding: 4px 8px; border-bottom: 1px solid #e5e7eb;
             vertical-align: top; }
    th { background: #f3f4f6; cursor: pointer; user-select: none; white-space: nowrap; }
    th:hover { background: #e5e7eb; }
    th::after { content: " \25B5"; color: #9ca3af; font-size: 0.6rem; }
    .mono { font-family: ui-monospace, monospace; font-size: 0.75rem; word-break: break-all; }
    .badge { display: inline-block; font-size: 0.65rem; padding: 1px 5px;
             border-radius: 3px; background: #dbeafe; color: #1d4ed8;
             margin: 1px 1px 0 0; }
    .CRITICAL { color: #b91c1c; font-weight: 700; }
    .HIGH { color: #c2410c; }
    .MEDIUM { color: #b45309; }
    .LOW { color: #15803d; }
    .why { font-size: 0.7rem; color: #374151; }
    footer { margin-top: 2rem; padding-top: 0.75rem; border-top: 1px solid #e5e7eb;
             font-size: 0.72rem; color: #6b7280; line-height: 1.5; }
    .empty { color: #6b7280; font-style: italic; padding: 1rem 0; }
  </style>
</head>
<body>

<h1>FalconEye</h1>
<p class="meta">
  Continuous threat intelligence for Philippine digital infrastructure &mdash;
  <strong>{{ generated_at }} UTC</strong> &nbsp;&middot;&nbsp;
  <a href="feed.xml">RSS</a> &nbsp;&middot;&nbsp;
  <a href="feed.json">JSON Feed</a> &nbsp;&middot;&nbsp;
  <a href="manifest.json">Manifest</a>
</p>

<div class="stats">
  <div class="stat">
    <div class="stat-n">{{ stats.ph_iocs }}</div>
    <div class="stat-l">PH IOCs</div>
  </div>
  <div class="stat">
    <div class="stat-n">{{ stats.ph_cves }}</div>
    <div class="stat-l">PH CVEs</div>
  </div>
  <div class="stat">
    <div class="stat-n">{{ stats.total_iocs }}</div>
    <div class="stat-l">URLhaus total</div>
  </div>
  <div class="stat">
    <div class="stat-n">{{ stats.total_cves }}</div>
    <div class="stat-l">CVEs (KEV+NVD)</div>
  </div>
  <div class="stat">
    <div class="stat-n">{{ stats.ph_asns }}</div>
    <div class="stat-l">PH ASNs</div>
  </div>
  <div class="stat">
    <div class="stat-n">{{ stats.ph_prefixes }}</div>
    <div class="stat-l">PH prefixes</div>
  </div>
</div>

<h2>PH-Matched IOCs ({{ iocs|length }})</h2>
{% if iocs %}
<table id="ioc-table">
  <thead><tr>
    <th onclick="sortTable('ioc-table',0)">First Seen</th>
    <th onclick="sortTable('ioc-table',1)">Type</th>
    <th onclick="sortTable('ioc-table',2)">Value</th>
    <th onclick="sortTable('ioc-table',3)">Threat</th>
    <th onclick="sortTable('ioc-table',4)">Tags</th>
    <th onclick="sortTable('ioc-table',5)">PH Signal</th>
    <th onclick="sortTable('ioc-table',6)">Source</th>
  </tr></thead>
  <tbody>
  {% for ioc in iocs %}
  <tr>
    <td class="mono">{{ (ioc.first_seen or ioc.fetched_at or '')[:10] }}</td>
    <td>{{ ioc.ioc_type }}</td>
    <td class="mono">{{ ioc.ioc_value }}</td>
    <td>{{ ioc.threat_type or '' }}</td>
    <td>{% for tag in ioc.tags_list %}<span class="badge">{{ tag }}</span>{% endfor %}</td>
    <td class="why">{{ ioc.why }}</td>
    <td>{{ ioc.source }}</td>
  </tr>
  {% endfor %}
  </tbody>
</table>
{% else %}
<p class="empty">No PH-matched IOCs in the current corpus.</p>
{% endif %}

<h2>PH-Matched CVEs ({{ cves|length }})</h2>
{% if cves %}
<table id="cve-table">
  <thead><tr>
    <th onclick="sortTable('cve-table',0)">CVE ID</th>
    <th onclick="sortTable('cve-table',1)">Severity</th>
    <th onclick="sortTable('cve-table',2)">Score</th>
    <th onclick="sortTable('cve-table',3)">Description</th>
    <th onclick="sortTable('cve-table',4)">KEV Added</th>
    <th onclick="sortTable('cve-table',5)">Ransomware</th>
    <th onclick="sortTable('cve-table',6)">PH Signal</th>
  </tr></thead>
  <tbody>
  {% for cve in cves %}
  <tr>
    <td><a href="https://nvd.nist.gov/vuln/detail/{{ cve.cve_id }}">{{ cve.cve_id }}</a></td>
    <td class="{{ cve.cvss_v3_severity or '' }}">{{ cve.cvss_v3_severity or 'N/A' }}</td>
    <td>{{ cve.cvss_v3_score or '' }}</td>
    <td>{{ cve.description or '' }}</td>
    <td class="mono">{{ cve.kev_date_added or '' }}</td>
    <td>{{ cve.kev_ransomware_use or '' }}</td>
    <td class="why">{{ cve.why }}</td>
  </tr>
  {% endfor %}
  </tbody>
</table>
{% else %}
<p class="empty">No PH-matched CVEs in the current corpus.</p>
{% endif %}

<footer>
  Threat intelligence sourced from
  <a href="https://urlhaus.abuse.ch/">abuse.ch URLhaus</a> (community use),
  <a href="https://www.cisa.gov/known-exploited-vulnerabilities-catalog">CISA KEV</a> (US Government public domain),
  <a href="https://nvd.nist.gov/">NVD</a> (US Government public domain), and
  <a href="https://www.apnic.net/">APNIC</a> delegated statistics.
  FalconEye is an independent OSINT-PH project and is not affiliated with these sources.
  Data is republished for Philippine community defense purposes.
  <a href="https://github.com/osintph/falconeye">GitHub</a> &mdash; AGPL v3.
</footer>

<script>
(function(){
  function sortTable(id, col) {
    var tbl = document.getElementById(id);
    var tbody = tbl.querySelector('tbody');
    var rows = Array.prototype.slice.call(tbody.querySelectorAll('tr'));
    var asc = tbl.dataset.sortCol == col && tbl.dataset.sortDir == 'asc';
    rows.sort(function(a, b) {
      var av = a.cells[col].textContent.trim();
      var bv = b.cells[col].textContent.trim();
      var an = parseFloat(av), bn = parseFloat(bv);
      if (!isNaN(an) && !isNaN(bn)) return asc ? bn - an : an - bn;
      return asc ? bv.localeCompare(av) : av.localeCompare(bv);
    });
    rows.forEach(function(r){ tbody.appendChild(r); });
    tbl.dataset.sortCol = col;
    tbl.dataset.sortDir = asc ? 'desc' : 'asc';
  }
  window.sortTable = sortTable;
})();
</script>
</body>
</html>
