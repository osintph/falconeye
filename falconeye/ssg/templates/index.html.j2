<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>FalconEye — PH Operational Threat Intelligence</title>
<style>
  *, *::before, *::after { box-sizing: border-box; }
  body { font-family: system-ui, -apple-system, sans-serif; max-width: 1200px;
         margin: 0 auto; padding: 1rem 1.5rem; color: #1a1a1a; background: #fff; }
  a { color: #1a56a5; }
  h1 { margin: 0 0 0.2rem; font-size: 1.6rem; color: #b91c1c; }
  h2 { font-size: 1rem; margin: 1.5rem 0 0.5rem; border-bottom: 1px solid #e5e7eb; padding-bottom: 4px; }
  .meta { font-size: 0.78rem; color: #6b7280; margin-bottom: 1rem; }
  .stats { display: flex; gap: 0.75rem; flex-wrap: wrap; margin: 0.75rem 0 1.25rem; }
  .stat { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 6px;
          padding: 0.45rem 0.9rem; min-width: 100px; }
  .stat-n { font-size: 1.3rem; font-weight: 700; color: #111; }
  .stat-l { font-size: 0.68rem; color: #6b7280; }
  .campaign-grid { display: grid; gap: 0.6rem; margin-bottom: 0.5rem; }
  .campaign-card { border: 1px solid #dbeafe; border-radius: 5px; padding: 0.65rem 0.9rem;
                   background: #f0f7ff; }
  .campaign-card-title { font-weight: 600; font-size: 0.9rem; margin-bottom: 0.15rem; }
  .campaign-card-summary { font-size: 0.8rem; color: #374151; margin-bottom: 0.2rem; }
  .campaign-card-meta { font-size: 0.72rem; color: #6b7280; }
  .badge-active { background: #d4edda; color: #155724; border-radius: 3px;
                  padding: 1px 5px; font-size: 0.7rem; }
  table { width: 100%; border-collapse: collapse; font-size: 0.8rem; }
  th { text-align: left; border-bottom: 2px solid #374151; padding: 4px 8px;
       background: #f9fafb; white-space: nowrap; }
  td { padding: 3px 8px; border-bottom: 1px solid #f0f0f0; vertical-align: top; }
  tr:hover td { background: #fafafa; }
  .CRITICAL { color: #b91c1c; font-weight: 700; }
  .HIGH { color: #c2410c; }
  .MEDIUM { color: #b45309; }
  .LOW { color: #15803d; }
  .mono { font-family: ui-monospace, monospace; font-size: 0.75rem; }
  .zero { color: #aaa; }
  .see-all { font-size: 0.78rem; }
  footer { margin-top: 2rem; padding-top: 0.75rem; border-top: 1px solid #e5e7eb;
           font-size: 0.7rem; color: #6b7280; line-height: 1.6; }
</style>
</head>
<body>

<h1>FalconEye</h1>
<p class="meta">
  Operational threat intelligence ledger for Philippine defenders &mdash;
  <strong>{{ generated_at }} UTC</strong> &nbsp;&middot;&nbsp;
  <a href="feed.xml">RSS</a> &middot;
  <a href="feed.json">JSON Feed</a> &middot;
  <a href="feed-iocs.xml">IOC stream</a> &middot;
  <a href="/api/v1/taxii/">STIX/TAXII</a> &middot;
  <a href="manifest.json">Manifest</a>
</p>

<div class="stats">
  <div class="stat">
    <div class="stat-n">{{ stats.ph_iocs or 0 }}</div>
    <div class="stat-l">PH IOCs</div>
  </div>
  <div class="stat">
    <div class="stat-n">{{ stats.ph_cves or 0 }}</div>
    <div class="stat-l">PH CVEs</div>
  </div>
  <div class="stat">
    <div class="stat-n">{{ stats.total_iocs or 0 }}</div>
    <div class="stat-l">URLhaus total</div>
  </div>
  <div class="stat">
    <div class="stat-n">{{ stats.total_cves or 0 }}</div>
    <div class="stat-l">CVEs (KEV+NVD)</div>
  </div>
  <div class="stat">
    <div class="stat-n">{{ stats.ph_asns or 0 }}</div>
    <div class="stat-l">PH ASNs</div>
  </div>
  <div class="stat">
    <div class="stat-n">{{ stats.ph_prefixes or 0 }}</div>
    <div class="stat-l">PH prefixes</div>
  </div>
</div>

<h2>Active Campaigns</h2>
{% if top_campaigns %}
<div class="campaign-grid">
  {% for c in top_campaigns %}
  <div class="campaign-card">
    <div class="campaign-card-title">
      <a href="/campaign/{{ c.slug }}/">{{ c.name }}</a>
      <span class="badge-active">active</span>
    </div>
    <div class="campaign-card-summary">{{ c.summary or '' }}</div>
    <div class="campaign-card-meta">
      {{ c.ioc_count }} IOCs &middot; last seen {{ (c.last_seen or '')[:10] or '&mdash;' }}
    </div>
  </div>
  {% endfor %}
</div>
<p class="see-all"><a href="/campaign/">View all campaigns &rarr;</a></p>
{% else %}
<p class="zero">No campaigns clustered yet — run the clustering worker after the first ingest cycle.</p>
{% endif %}

<h2>Active PH ASNs</h2>
{% if active_asns %}
<table>
  <thead>
    <tr><th>ASN</th><th>Operator</th><th>IOCs (30d)</th><th>Last seen</th></tr>
  </thead>
  <tbody>
    {% for a in active_asns %}
    <tr>
      <td><a href="/asn/AS{{ a.asn }}/">AS{{ a.asn }}</a></td>
      <td>{{ a.short or a.name or ('AS' ~ a.asn) }}</td>
      <td>{{ a.ioc_count }}</td>
      <td class="mono">{{ (a.last_seen or '')[:10] or '&mdash;' }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
<p class="see-all"><a href="/asn/">View all PH ASNs &rarr;</a></p>
{% else %}
<p class="zero">No IOC activity on PH ASNs yet.</p>
{% endif %}

<h2>Latest CVE Activity (PH-relevant)</h2>
{% if cves %}
<table>
  <thead>
    <tr>
      <th>CVE</th>
      <th>Severity</th>
      <th>Score</th>
      <th>Description</th>
      <th>KEV added</th>
    </tr>
  </thead>
  <tbody>
    {% for cve in cves[:10] %}
    <tr>
      <td><a href="https://nvd.nist.gov/vuln/detail/{{ cve.cve_id }}">{{ cve.cve_id }}</a></td>
      <td class="{{ cve.cvss_v3_severity or '' }}">{{ cve.cvss_v3_severity or 'N/A' }}</td>
      <td>{{ cve.cvss_v3_score or '' }}</td>
      <td>{{ (cve.description or '')[:120] }}</td>
      <td class="mono">{{ cve.kev_date_added or '' }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
<p class="zero">No PH-matched CVEs in the current corpus.</p>
{% endif %}

<footer>
  Sources:
  <a href="https://urlhaus.abuse.ch/">URLhaus</a> &middot;
  <a href="https://www.cisa.gov/known-exploited-vulnerabilities-catalog">CISA KEV</a> &middot;
  <a href="https://nvd.nist.gov/">NVD</a> &middot;
  <a href="https://www.apnic.net/">APNIC</a> &middot;
  <a href="https://internetdb.shodan.io/">Shodan InternetDB</a>
  &nbsp;&mdash;&nbsp;
  <a href="/api/v1/taxii/">STIX/TAXII feed</a> &middot;
  <a href="https://blog.osintph.info">Blog</a> &middot;
  <a href="https://github.com/osintph/falconeye">GitHub</a> &middot;
  AGPL v3 &middot;
  FalconEye is an independent OSINT-PH project.
</footer>
</body>
</html>
