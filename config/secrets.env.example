URLHAUS_AUTH_KEY=replace-with-key-from-https://auth.abuse.ch
NVD_API_KEY=replace-with-key-from-https://nvd.nist.gov/developers/request-an-api-key
FALCONEYE_DB_PATH=/opt/falconeye/db/falconeye.db
FALCONEYE_OUTPUT_DIR=/opt/falconeye/public

# Ghost digest (optional — digest module is a no-op if these are unset)
# Obtain the admin API key at Ghost Admin → Settings → Integrations → Add custom integration
GHOST_API_URL=https://blog.osintph.info
GHOST_ADMIN_KEY=id_hex:secret_hex
GHOST_AUTHOR_SLUG=sigmund
# Set to 'published' to auto-publish digests (default: 'draft')
FALCONEYE_DIGEST_MODE=draft
